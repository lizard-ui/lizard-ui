{
  "name": "lizard-ui",
  "version": "0.0.1",
  "description": "Lizard UI — modern, stylish, minimalist React components. ESM/CJS package for Vite, Bun, and other bundlers.",
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.cjs",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    ".github/ISSUE_TEMPLATE",
    ".github/workflows",
    ".github/pull_request_template.md",
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "rollup -c",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,md}\"",
    "typecheck": "tsc --noEmit",
    "build:site": "vite build",
    "dev": "vite",
    "dev:all": "pwsh -ExecutionPolicy Bypass -File scripts/dev.ps1",
    "dev:test": "pwsh -ExecutionPolicy Bypass -File scripts/dev.ps1 -Task test",
    "dev:build": "pwsh -ExecutionPolicy Bypass -File scripts/dev.ps1 -Task build",
    "dev:lint": "pwsh -ExecutionPolicy Bypass -File scripts/dev.ps1 -Task lint",
    "dev:typecheck": "pwsh -ExecutionPolicy Bypass -File scripts/dev.ps1 -Task typecheck",
    "prepublishOnly": "bun run build && bun run test && bun run lint && bun run typecheck",
    "setup": "node scripts/setup.js",
    "setup:ps": "pwsh -ExecutionPolicy Bypass -File scripts/setup.ps1",
    "release": "node scripts/release.js patch",
    "release:minor": "node scripts/release.js minor",
    "release:major": "node scripts/release.js major",
    "release:ps": "pwsh -ExecutionPolicy Bypass -File scripts/release.ps1",
    "release:ps:minor": "pwsh -ExecutionPolicy Bypass -File scripts/release.ps1 -VersionType minor",
    "release:ps:major": "pwsh -ExecutionPolicy Bypass -File scripts/release.ps1 -VersionType major"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lizard-ui/lizard-ui.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/lizard-ui/lizard-ui#readme",
  "bugs": {
    "url": "https://github.com/lizard-ui/lizard-ui/issues"
  },
  "keywords": [
    "lizard-ui",
    "react",
    "components",
    "ui",
    "design-system",
    "minimal",
    "minimalist",
    "typescript",
    "vite",
    "bun",
    "esm",
    "glassmorphism",
    "tailwindcss",
    "shadcn"
  ],
  "author": {
    "name": "Xarlizard",
    "email": "38315638+xarlizard@users.noreply.github.com",
    "url": "https://github.com/xarlizard"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "tailwindcss": "^3.4.0",
    "lucide-react": "^0.263.0"
  },
  "peerDependenciesMeta": {
    "tailwindcss": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@jest/globals": "^30.3.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.51.0",
    "@typescript-eslint/parser": "^8.55.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.27",
    "clsx": "^2.1.1",
    "eslint": "^9.39.2",
    "globals": "^16.5.0",
    "jest": "^30.3.0",
    "lucide-react": "0.577.0",
    "postcss": "^8.5.8",
    "prettier": "^3.7.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rollup": "^4.54.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "3",
    "ts-jest": "^29.4.6",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1"
  }
}
