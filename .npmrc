# Default registry. Do not set @scope:registry to GitHub here — it would make
# `npm publish` for @lizard-ui/* target GitHub Packages instead of npmjs.org.
registry=https://registry.npmjs.org/

# To install this package from GitHub Packages locally, add to ~/.npmrc (not committed):
# @lizard-ui:registry=https://npm.pkg.github.com
# //npm.pkg.github.com/:_authToken=<GITHUB_TOKEN or PAT with read:packages>
